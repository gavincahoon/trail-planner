generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id              String   @id @default(cuid())
  name            String
  location        String
  park            String
  days            Int
  elevationGain   Int      @default(0)
  difficulty      String
  terrain         String
  featured        Boolean  @default(false)
  description     String

  day1            String
  day2            String
  day3            String
  day4            String?

  permitRequired  Boolean
  permitLink      String?
  bestSeason      String?
  trailheadInfo   String?
  parkingInfo     String?
  packingList     String?
  whyThisTrip     String?

  createdAt       DateTime @default(now())
}